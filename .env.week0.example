# Week 0 setup values for WP LaunchGuard hybrid MVP.
# Copy to .env.week0.local and fill each value.

# General
PROJECT_SLUG=wplaunchguard
DEFAULT_REGION=eu

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_WORKERS_SUBDOMAIN=

# Cloudflare resource names (you can change these)
CF_D1_DB_NAME=launchguard-db-dev
CF_R2_BUCKET=launchguard-reports-dev
CF_QUEUE_NAME=launchguard-scan-jobs-dev

# GitHub
GITHUB_ORG_OR_USER=
GITHUB_REPO=
GITHUB_TOKEN=
GITHUB_ACTIONS_REF=main

# Stripe (test first, then live)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_GROWTH=
STRIPE_PRICE_ID_AGENCY=

# App secrets
JWT_SIGNING_KEY=
ENCRYPTION_KEY=

# Optional error tracking
SENTRY_DSN=
